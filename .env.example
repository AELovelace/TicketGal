ATERA_API_KEY=your_atera_api_key_here
ATERA_BASE_URL=https://app.atera.com
HOST=127.0.0.1
PORT=8000
WEB_CONCURRENCY=2
AUTO_KILL_PORT=0
USER_PASSWORD_AUTH_ENABLED=0
DB_PATH=ticketgal.db
DATA_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=ticketgal_session
SESSION_HOURS=12
ALLOWED_EMAIL_DOMAINS=
ADMIN_EMAIL=
ADMIN_PASSWORD=change_this_admin_password
OPENAI_BASE_URL=https://your-ollama-url/
OPENAI_MODEL=qwen3.5:4b

MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=organizations
ALLOWED_MICROSOFT_TENANT_IDS=tenant_id_1,tenant_id_2
PUBLIC_BASE_URL=
MICROSOFT_SCOPES=User.Read,email
MICROSOFT_PROMPT=select_account

# Optional local HTTPS for direct uvicorn TLS (keep disabled when behind nginx/ingress TLS)
HTTPS_ENABLED=0
AUTO_GENERATE_DEV_CERT=1
TICKETGAL_SSL_CERT_FILE=certs/dev-cert.pem
TICKETGAL_SSL_KEY_FILE=certs/dev-key.pem