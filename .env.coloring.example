# TicketGal — Base Color Theme (example)
# Copy this file to .env.coloring and adjust values to retheme the portal.
# These values are loaded at startup and served via /theme.css as CSS custom properties.
# Accepts any valid CSS color value (hex, rgb, rgba, hsl, named keywords).
# COLOR_SHADOW accepts any valid CSS box-shadow value.

COLOR_NAVY_900=#0e1c2f
COLOR_NAVY_800=#142a45
COLOR_NAVY_700=#1f3f66
COLOR_GOLD_500=#c6a75d
COLOR_GOLD_400=#d8bb79
COLOR_PAPER=#f8f5ed
COLOR_CARD=#fffdf8
COLOR_INK=#192432
COLOR_MUTED=#617086
COLOR_LINE=#ddd4c1
COLOR_SHADOW=0 14px 26px rgba(8, 18, 30, 0.12)
